{
  "title": "LLM Service Latency",
  "uid": "llm-service-latency",
  "tags": ["llm", "bedrock", "latency", "ai"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "First Token Latency (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(llm_first_token_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_first_token_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(llm_first_token_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 3, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "LLM Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(llm_requests_total[5m])) by (model_id)",
          "legendFormat": "{{ model_id }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "title": "LLM Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(llm_requests_total{status=\"error\"}[5m])) / sum(rate(llm_requests_total[5m]))",
          "legendFormat": "Error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.05, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Bedrock ThrottlingException Rate",
      "type": "stat",
      "description": "Bedrock returns ThrottlingException when account quota is exceeded",
      "gridPos": { "x": 0, "y": 18, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(llm_bedrock_errors_total{error_type=\"ThrottlingException\"}[5m]))",
          "legendFormat": "Throttle rate"
        }
      ]
    }
  ]
}
